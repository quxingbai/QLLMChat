<UserControl x:Class="QLLMChat.Views.Pages.MainChatPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QLLMChat.Views.Pages"
             mc:Ignorable="d" 
             xmlns:vms="clr-namespace:QLLMChat.ViewModels"
             xmlns:cc="clr-namespace:QLLMChat.Views.CControls"
             d:DesignHeight="450" d:DesignWidth="800" Background="WhiteSmoke">
    <Grid>
        <Grid.Resources>
            <Style TargetType="ListBoxItem" x:Key="ChatRargetItemStyle">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="ContextMenu">
                    <Setter.Value>
                        <ContextMenu>
                            <MenuItem Header="设置"/>
                        </ContextMenu>
                    </Setter.Value>
                </Setter> 
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border Background="{TemplateBinding Background}" Padding="10,12" Margin="10,2" BorderBrush="DodgerBlue" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="20">
                                <Grid Width="155">
                                    <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#10000000"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#E5EDFD"/>
                                    <Setter Property="Foreground" Value="DodgerBlue"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="215"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Background="WhiteSmoke" >
                <Grid >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="100"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border>
                        <Grid>
                            <Border Margin="15" VerticalAlignment="Center">
                                <Button Content="创建新对话" HorizontalContentAlignment="Center" Command="{Binding COMMAND_CreateNewChatTarget}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="DodgerBlue" Padding="10,10" CornerRadius="5">
                                                <Grid>
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Border>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" >
                        <ListBox FocusVisualStyle="{x:Null}"  SelectedItem="{Binding SelectedChatTarget}" ItemContainerStyle="{DynamicResource ChatRargetItemStyle}" ItemsSource="{Binding ChatTargets}" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Hidden">
                        </ListBox>
                    </Border>
                </Grid>
            </Border>
            <Border Grid.Column="1" Background="White" Margin="15" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="Transparent" Padding="10">
                        <TextBlock  Foreground="Black" Opacity="0.2" FontWeight="Bold">
                            <Run Text="{Binding SelectedChatTarget.Title,Mode=OneWay}"/>
                            <Run Text="  "/>
                            <Run Text="{Binding SelectedChatTarget.ChatType.Text,Mode=OneWay}"/>
                        </TextBlock>
                    </Border>
                    <!--<ContentControl Content="{Binding ChatPageContent}">-->
                    <ContentControl FocusVisualStyle="{x:Null}" Grid.Row="1" Content="{Binding ChatPageContent}">
                        <ContentControl.Resources>
                            <DataTemplate DataType="{x:Type vms:ChatPageViewModel}">
                                <Grid>
                                    <ScrollViewer Name="SCROLL_ChatPage" ScrollChanged="SCROLL_ChatPage_ScrollChanged" Loaded="SCROLL_ChatPage_Loaded">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="200"/>
                                            </Grid.RowDefinitions>
                                            <local:ChatPage DataContext="{Binding .}"/>
                                            <Border Grid.Row="1" />
                                        </Grid>
                                    </ScrollViewer>
                                    <Border Grid.Row="1"  VerticalAlignment="Bottom" Background="White" Padding="30,0" HorizontalAlignment="Center" DataContext="{Binding RelativeSource={RelativeSource AncestorType=local:MainChatPage},Path=DataContext}">
                                        <Grid>
                                            <cc:InputBox Text="{Binding Text,Mode=TwoWay}" IsSending="{Binding IsSending}" Width="850" MinHeight="130" Margin="0,0,0,40" SendCommand="{Binding COMMAND_Send}" CancelCommand="{Binding COMMAND_Cancel}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vms:FirstChatPageViewModel}">
                                <local:FirstChatPage DataContext="{Binding .}"/>
                            </DataTemplate>
                        </ContentControl.Resources>
                    </ContentControl>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
