        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:WpfElementRenderBox}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>-->

    <Style TargetType="{x:Type local:CustomRenderCard}">
        <Setter Property="Background" Value="White"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:CustomRenderCard}">
                    <Grid>
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="0" Opacity="0.2" Color="Black"/>
                            </Border.Effect>
                        </Border>
                        <Border Background="{TemplateBinding Background}" Margin="5" CornerRadius="5" Padding="15"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0">
                                    <Grid>
                                        <Border HorizontalAlignment="Left">
                                            <ToggleButton FocusVisualStyle="{x:Null}" VerticalAlignment="Center" FontSize="11" Foreground="DimGray" Content="代码" IsChecked="{Binding RelativeSource={RelativeSource Mode=TemplatedParent},Path=IsShowSourceCode,UpdateSourceTrigger=PropertyChanged}">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="Transparent" CornerRadius="5" Padding="5,2">
                                                            <Grid>
                                                                <Border Name="BD_MARK" Background="DodgerBlue" CornerRadius="2" Width="10" Padding="10,0"/>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Name="BD_Code">
                                                                        <TextBlock Text="代码" VerticalAlignment="Center" Name="TEXT_Code"/>
                                                                    </Border>
                                                                    <Border Width="5" Grid.Column="1">
                                                                        <TextBlock Text="/" FontSize="8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <Border Name="BD_Render" Grid.Column="2">
                                                                        <TextBlock Text="渲染" VerticalAlignment="Center" Name="TEXT_Render"/>
                                                                    </Border>
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter Property="HorizontalAlignment" Value="Left" TargetName="BD_MARK"/>
                                                                <Setter Property="MinWidth" Value="{Binding ElementName=BD_Code,Path=ActualWidth}" TargetName="BD_MARK"/>
                                                                <Setter Property="Foreground" Value="White" TargetName="TEXT_Code"/>
                                                            </Trigger>
                                                            <Trigger Property="IsChecked" Value="False">
                                                                <Setter Property="HorizontalAlignment" Value="Right" TargetName="BD_MARK"/>
                                                                <Setter Property="MinWidth" Value="{Binding ElementName=BD_Render,Path=ActualWidth}" TargetName="BD_MARK"/>
                                                                <Setter Property="Foreground" Value="White" TargetName="TEXT_Render"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                        </Border>
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Center" Margin="2" Background="WhiteSmoke" CornerRadius="2" Padding="10,5" Opacity="0.25">
                                            <TextBlock Text="{TemplateBinding CodeLanguage}" Foreground="dimgray"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <Border Grid.Row="1">
                                    <Grid>
                                        <Grid Name="GD_Content">
                                            <ContentPresenter/>
                                        </Grid>
                                        <Grid Name="GD_SourceCode" Visibility="Collapsed">
                                            <TextBox IsReadOnly="True" BorderThickness="0" Background="Transparent" Name="TEXT_SourceCodeDisplay" Text="{TemplateBinding SourceCode}"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                                <Border Grid.Row="2">
                                    <Grid>
                                        <TextBlock Opacity="0.15" DataContext="{Binding .}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontWeight="Bold">
                                             <Run Text="运行示例"/>
                                        </TextBlock>
                                        <WrapPanel HorizontalAlignment="Right">
                                            <Button Content="复制代码" Margin="0,10,0,0"  Name="BT_Copy" Command="{TemplateBinding COMMAND_Copy}"/>
                                        </WrapPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup Name="CopyButtonGroup">
                                <VisualState Name="STATE_CopySuccess">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BT_Copy" Storyboard.TargetProperty="(Button.Content)">
                                            <DiscreteObjectKeyFrame Value="成功" KeyTime="0:0:0"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState Name="STATE_CopyError">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BT_Copy" Storyboard.TargetProperty="Content" >
                                            <DiscreteObjectKeyFrame Value="失败" KeyTime="0"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState Name="STATE_Default">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BT_Copy" Storyboard.TargetProperty="Content">
                                            <DiscreteObjectKeyFrame Value="复制代码" KeyTime="0"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsShowSourceCode" Value="True">
                            <Setter TargetName="GD_Content" Property="Visibility"  Value="Collapsed"/>
                            <Setter TargetName="GD_SourceCode" Property="Visibility"  Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
