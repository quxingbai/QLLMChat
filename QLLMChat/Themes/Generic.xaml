<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:QLLMChat.Views.CControls">


    <Style TargetType="{x:Type local:InputBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:InputBox}">
                    <Grid>
                        <Border Background="White" CornerRadius="5">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="0" Opacity="0.5" Color="Black"/>
                            </Border.Effect>
                        </Border>
                        <Border Margin="0" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <Border Padding="5" Background="White" CornerRadius="5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Padding="5" Background="White" CornerRadius="5">
                                        <ScrollViewer VerticalScrollBarVisibility="Hidden">
                                            <TextBox AcceptsReturn="True" Background="Transparent" Text="{Binding Text,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Name="TEXT_INPUIT" BorderThickness="0" BorderBrush="Transparent" FontSize="15"/>
                                        </ScrollViewer>
                                    </Border>
                                    <Border Grid.Row="1" Margin="10">
                                        <Grid>
                                            <TextBlock Text="input text message" HorizontalAlignment="Left" VerticalAlignment="Bottom" Foreground="LightGray"/>
                                            <Grid  HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                                <Button  Command="{TemplateBinding SendCommand}" CommandParameter="{Binding ElementName=TEXT_INPUIT,Path=Text}" Foreground="White" VerticalAlignment="Bottom" Content="Send" Name="BT_SendBt" Visibility="Visible"/>
                                                <Button Background="OrangeRed" Command="{TemplateBinding CancelCommand}" CommandParameter="{TemplateBinding Text}" Foreground="White" VerticalAlignment="Bottom" Content="Cancel" Name="BT_CancelBt" Visibility="Visible"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Border>

                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSending" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" TargetName="BT_CancelBt"/>
                            <Setter Property="Visibility" Value="Visible" TargetName="BT_SendBt"/>
                        </Trigger>
                        <Trigger Property="IsSending" Value="True">
                            <Setter Property="Visibility" Value="Visible" TargetName="BT_CancelBt"/>
                            <Setter Property="Visibility" Value="Collapsed" TargetName="BT_SendBt"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
